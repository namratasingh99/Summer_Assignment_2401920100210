class Solution {
    public int maxProfit(int[] prices) {
        int profit = 0 ;
        int sell=0;
        for(int i=0 ; i<prices.length ; i++){
            if(prices[i]<prices[sell]){
                sell = i;
            }
            if(profit <(prices[i]-prices[sell])){
                profit = prices[i]-prices[sell];
            }
            
        }
        return profit;
    }
}
